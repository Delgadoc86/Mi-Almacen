# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Firebase Admin SDK service account key — nunca se commitea. El script de
# migración usa Application Default Credentials (variable de entorno
# GOOGLE_APPLICATION_CREDENTIALS apuntando FUERA del repo), así que no
# debería aparecer ningún archivo de este tipo acá — estos patrones son
# protección adicional por si alguno se cae adentro por error.
**/*serviceAccount*.json
**/*service-account*.json
**/*firebase-admin*.json

# Firebase emulator local state
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
